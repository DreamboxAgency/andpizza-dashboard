# ============================================================
# &Pizza Media Dashboard — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in all values.
# Never commit .env.local to version control.
# Add all of these to Vercel's Environment Variables dashboard too.
# ============================================================

# --- SUPABASE ---
# Found in: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- ANTHROPIC ---
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# --- AZURE AD (Microsoft Login) ---
# Found in: Azure Portal → App Registrations → your app
# Your IT team registers the app and provides these three values.
# Redirect URI to give IT: https://YOUR_VERCEL_URL/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=your_azure_client_id_here
AZURE_AD_CLIENT_SECRET=your_azure_client_secret_here
AZURE_AD_TENANT_ID=your_azure_tenant_id_here

# --- NEXTAUTH ---
# Generate a secret by running: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=https://YOUR_VERCEL_URL
